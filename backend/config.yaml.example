# ============================
# AgenticOps 配置文件（示例）
# 复制为 config.yaml 后填入实际值
# ============================

app:
  name: AgenticOps
  debug: true
  version: "1.0.0"

mysql:
  default:
    host: localhost
    port: 3306
    user: root
    password: "your_password"
    database: agenticops

redis:
  default:
    host: localhost
    port: 6379
    password: ""
    db: 0
    cache_prefix: agenticops

jwt:
  secret_key: "change-me-to-a-random-string"
  algorithm: HS256
  access_token_expire_minutes: 30
  refresh_token_expire_days: 7

cors:
  origins:
    - "http://localhost:5173"

ai:
  openai:
    enabled: false
    api_key: ""
    base_url: "https://api.openai.com/v1"
    model: "gpt-4o"
  deepseek:
    enabled: false
    api_key: ""
    base_url: "https://api.deepseek.com/v1"
    model: "deepseek-chat"
