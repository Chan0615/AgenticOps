# ============================
# CHAN AgenticOps 配置文件（示例）
# 复制为 config.yaml 后填入实际值
# ============================

app:
  name: CHAN AgenticOps
  debug: true
  version: "1.0.0"

mysql:
  default:
    host: 10.225.138.121
    port: 3306
    user: root
    password: "CAr8RvRA"
    database: kefu_ai

redis:
  default:
    host: 10.225.138.125
    port: 6579
    password: "leadton@qwe"
    db: 20
    cache_prefix: agenticops

jwt:
  secret_key: "change-me-to-a-random-string"
  algorithm: HS256
  access_token_expire_minutes: 30
  refresh_token_expire_days: 7

cors:
  origins:
    - "http://localhost:5173"

ai:
  openai:
    enabled: false
    api_key: ""
    base_url: "https://api.openai.com/v1"
    model: "gpt-4o"
  deepseek:
    enabled: false
    api_key: ""
    base_url: "https://api.deepseek.com/v1"
    model: "deepseek-chat"

jumpserver:
  base_url: "https://jumpserver.example.com"
  auth_mode: "private_token"  # private_token 或 password
  private_token: ""
  username: ""
  password: ""
  org_id: "00000000-0000-0000-0000-000000000002"

saltstack:
  # 富春云环境
  fuchunyun:
    url: http://10.66.108.97
    salt_name: saltapi
    salt_pass: "your_salt_password"
  # 阿里云环境
  aliyun:
    url: http://10.136.74.9
    salt_name: saltapi
    salt_pass: "your_salt_password"
  # 滨江环境
  binjiang:
    url: http://10.225.141.64
    salt_name: saltapi
    salt_pass: "your_salt_password"
  # 阿里云压测环境
  aliyunyc:
    url: http://10.200.255.63
    salt_name: saltapi
    salt_pass: "your_salt_password"

ops:
  logs:
    # 日志列表默认只查最近N天；0表示不限制
    default_recent_days: 30
    cleanup:
      enabled: true
      # 每天执行归档清理的时间（24小时制）
      run_hour: 3
      run_minute: 10
      # 在线日志保留天数
      retention_days: 90
      # 单批处理条数与最大批次数（避免单次任务过重）
      batch_size: 2000
      max_batches: 20
      # 是否归档后再删除主表数据
      archive_enabled: true
      archive_table: ops_task_execution_log_archive
