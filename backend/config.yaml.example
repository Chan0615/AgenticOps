# ============================
# CHAN AgenticOps 配置文件（示例）
# 复制为 config.yaml 后填入实际值
# ============================

app:
  name: CHAN AgenticOps
  debug: true
  version: "1.0.0"

mysql:
  default:
    host: 10.225.138.121
    port: 3306
    user: root
    password: "CAr8RvRA"
    database: kefu_ai

redis:
  default:
    host: 10.225.138.125
    port: 6579
    password: "leadton@qwe"
    db: 20
    cache_prefix: agenticops

jwt:
  secret_key: "change-me-to-a-random-string"
  algorithm: HS256
  access_token_expire_minutes: 30
  refresh_token_expire_days: 7

cors:
  origins:
    - "http://localhost:5173"

ai:
  openai:
    enabled: false
    api_key: ""
    base_url: "https://api.openai.com/v1"
    model: "gpt-4o"
  deepseek:
    enabled: false
    api_key: ""
    base_url: "https://api.deepseek.com/v1"
    model: "deepseek-chat"

jumpserver:
  base_url: "https://jumpserver.example.com"
  auth_mode: "private_token"  # private_token 或 password
  private_token: ""
  username: ""
  password: ""
  org_id: "00000000-0000-0000-0000-000000000002"

saltstack:
  # 富春云环境
  fuchunyun:
    url: http://10.66.108.97
    salt_name: saltapi
    salt_pass: "your_salt_password"
  # 阿里云环境
  aliyun:
    url: http://10.136.74.9
    salt_name: saltapi
    salt_pass: "your_salt_password"
  # 滨江环境
  binjiang:
    url: http://10.225.141.64
    salt_name: saltapi
    salt_pass: "your_salt_password"
  # 阿里云压测环境
